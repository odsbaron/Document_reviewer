# AIHubMix uses an OpenAI-compatible endpoint.
# API keys should be stored in system keyring instead of this file:
#   .\.venv\Scripts\doc-review-agent.exe store-key
#
# The default keyring entry is:
#   service:  aihubmix
#   username: sjqy
#
# Optional fallback if you really want environment variables:
# AIHUBMIX_API_KEY=replace-with-your-key
AIHUBMIX_BASE_URL=https://aihubmix.com/v1

# Optional. For compatible providers, set this to that provider's model name.
AIHUBMIX_MODEL=gpt-4o-mini

# Optional tuning.
OPENAI_TEMPERATURE=0.1
OPENAI_TIMEOUT_SECONDS=120
REVIEW_MAX_CHUNK_CHARS=8000
